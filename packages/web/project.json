{
  "name": "web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/web/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/web",
        "command": "vite"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/web",
        "command": "vite"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/web"],
      "options": {
        "cwd": "packages/web",
        "command": "vite build"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "packages/web",
        "command": "vite preview"
      }
    }
  },
  "implicitDependencies": ["drag-canvas"]
}
