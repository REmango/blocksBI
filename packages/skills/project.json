{
  "name": "skills",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/skills/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "packages/skills/dist",
        "tsConfig": "packages/skills/tsconfig.lib.json",
        "packageJson": "packages/skills/package.json",
        "main": "packages/skills/src/index.ts",
        "assets": [
          {
            "input": "packages/skills/skills",
            "glob": "**/*",
            "output": "skills"
          },
          {
            "input": "packages/skills",
            "glob": "*.md",
            "output": "."
          }
        ]
      }
    }
  }
}
